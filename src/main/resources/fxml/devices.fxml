<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.controller.DeviceController">

    <!-- Background Image (set dynamically in Controller) -->
    <?import javafx.scene.layout.Pane?>

<!-- Background layer -->
<Pane fx:id="backgroundPane" style="-fx-background-size: cover; -fx-background-position: center center;" />

<!-- Dim overlay -->
<Pane style="-fx-background-color: rgba(0,0,0,0.55);" />

    <!-- Content -->
    <BorderPane>

        <top>
            <VBox alignment="CENTER" spacing="5.0">
                <padding>
                    <Insets top="20.0" bottom="10.0" />
                </padding>
                <Label fx:id="roomNameLabel" text="Room Devices" styleClass="dashboard-title" />
            </VBox>
        </top>

        <center>
            <VBox alignment="TOP_CENTER" spacing="12.0">
                <padding>
                    <Insets top="10.0" left="40.0" right="40.0" bottom="10.0" />
                </padding>

                <ListView fx:id="devicesListView" prefHeight="300.0" maxWidth="550.0" />

                <HBox alignment="CENTER" spacing="10.0">
                    <Button fx:id="turnOnButton" text="Turn ON" onAction="#handleTurnOn" />
                    <Button fx:id="turnOffButton" text="Turn OFF" onAction="#handleTurnOff" />
                    <Button fx:id="viewDetailsButton" text="View Details" onAction="#handleViewDetails" />
                    <Button fx:id="removeDeviceButton" text="Remove" onAction="#handleRemoveDevice" />
                    <Button fx:id="unlockButton" text="Unlock" onAction="#handleUnlock" />
                    <Button fx:id="lockButton" text="Lock" onAction="#handleLock" />
                    <Button fx:id="simulateButton" text="Simulate Detect" onAction="#handleSimulateDetection" />
                </HBox>

                <Label text="Add New Device" styleClass="section-title" />

                <HBox alignment="CENTER" spacing="10.0">
                    <TextField fx:id="newDeviceNameField" promptText="Device name" maxWidth="150.0" />
                    <ComboBox fx:id="deviceTypeComboBox" promptText="Select type" prefWidth="140.0" />
                    <Button fx:id="addDeviceButton" text="Add Device" onAction="#handleAddDevice" />
                </HBox>

            </VBox>
        </center>

        <bottom>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <padding>
                    <Insets top="10.0" bottom="10.0" left="20.0" />
                </padding>
                <Button fx:id="backButton" text="Back to Rooms" onAction="#handleBack" />
            </HBox>
        </bottom>

    </BorderPane>

</StackPane>