<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.controller.SignUpController" styleClass="login-background">

    <VBox alignment="CENTER" spacing="10.0" styleClass="login-container" maxWidth="350.0" maxHeight="600.0">

        <padding>
            <Insets top="30.0" bottom="30.0" left="40.0" right="40.0" />
        </padding>

        <Label text="Create Account" styleClass="login-title" />

        <Label text="Sign up to get started" styleClass="login-subtitle" />

        <Label text="Name" styleClass="field-label" maxWidth="250.0" alignment="CENTER_LEFT" />
        <TextField fx:id="nameField" promptText="Enter your full name" maxWidth="250.0" />

        <Label text="Username" styleClass="field-label" maxWidth="250.0" alignment="CENTER_LEFT" />
        <TextField fx:id="usernameField" promptText="Choose a username" maxWidth="250.0" />

        <Label text="Email" styleClass="field-label" maxWidth="250.0" alignment="CENTER_LEFT" />
        <TextField fx:id="emailField" promptText="Enter your email" maxWidth="250.0" />

        <Label text="Password" styleClass="field-label" maxWidth="250.0" alignment="CENTER_LEFT" />
        <PasswordField fx:id="passwordField" promptText="Create a password" maxWidth="250.0" />

        <Label text="Confirm Password" styleClass="field-label" maxWidth="250.0" alignment="CENTER_LEFT" />
        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" maxWidth="250.0" />

        <Label fx:id="errorLabel" styleClass="error-label" visible="false" />

        <Button fx:id="signUpButton" text="Sign Up" onAction="#handleSignUp" defaultButton="true" maxWidth="250.0" />

        <Hyperlink fx:id="backToLoginLink" text="Already have an account? Login" onAction="#handleBackToLogin" />

    </VBox>

</StackPane>